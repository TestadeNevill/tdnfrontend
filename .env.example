# Client-side (embedded at build time — must use VITE_ prefix)
VITE_FORMSPREE_ID=your_formspree_form_id

# Server-side (Vercel Functions only — never expose to the browser)
# Set the same vars in Vercel → Project → Settings → Environment Variables, then redeploy.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google Places API (server-side — parks & business POI layers)
# Enable Places API (New) + Places API in GCP; restrict key to server/API use only.
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Map layer APIs (server-side — optional, layers degrade gracefully)
# OPENROUTESERVICE_API_KEY=your_ors_key
# AIRNOW_API_KEY=your_airnow_key
# TRANSITLAND_API_KEY=your_transitland_key
# CENSUS_API_KEY=your_census_key
# NREL_API_KEY=your_nrel_key
