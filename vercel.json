{
  "functions": {
    "api/labs/parks/nearby.js": {
      "maxDuration": 15
    },
    "api/labs/parks/photo.js": {
      "maxDuration": 15
    },
    "api/labs/maps/*.js": {
      "maxDuration": 15
    },
    "api/labs/ai/complete.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
